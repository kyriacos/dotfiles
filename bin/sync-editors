#!/usr/bin/env zsh
# Sync extensions and settings between VS Code and Cursor (bidirectional)

VSCODE_SETTINGS="$HOME/Library/Application Support/Code/User/settings.json"
CURSOR_SETTINGS="$HOME/Library/Application Support/Cursor/User/settings.json"

for cmd in fzf python3; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Required: $cmd  (brew install $cmd)"
    exit 1
  fi
done

# ── Direction ─────────────────────────────────────────────────────────────────
direction=$(printf "cursor → vscode\nvscode → cursor" | \
  fzf --prompt="Sync direction: " --height=5 --border --no-multi) || exit 0

if [[ "$direction" == "cursor → vscode" ]]; then
  SRC_SETTINGS="$CURSOR_SETTINGS"; DST_SETTINGS="$VSCODE_SETTINGS"
  SRC_CMD="cursor";                DST_CMD="code"
  src_label="Cursor";              dst_label="VS Code"
else
  SRC_SETTINGS="$VSCODE_SETTINGS"; DST_SETTINGS="$CURSOR_SETTINGS"
  SRC_CMD="code";                  DST_CMD="cursor"
  src_label="VS Code";             dst_label="Cursor"
fi

# ── Extensions ────────────────────────────────────────────────────────────────
echo "\n── Extensions ($src_label → $dst_label) ──────────────────────────────────────"

$SRC_CMD --list-extensions 2>/dev/null | sort > /tmp/sync_src_ext.txt
$DST_CMD --list-extensions 2>/dev/null | sort > /tmp/sync_dst_ext.txt
comm -23 /tmp/sync_src_ext.txt /tmp/sync_dst_ext.txt > /tmp/sync_ext_diff.txt

ext_count=$(grep -c . /tmp/sync_ext_diff.txt 2>/dev/null || echo 0)

if [[ $ext_count -gt 0 ]]; then
  selected_exts=$(cat /tmp/sync_ext_diff.txt | \
    fzf --multi \
      --prompt="Install in $dst_label > " \
      --header="$ext_count extensions in $src_label not in $dst_label  |  TAB select  CTRL-A all  ENTER confirm" \
      --height=60% --border \
      --bind='ctrl-a:select-all') || true

  if [[ -n "$selected_exts" ]]; then
    echo "$selected_exts" | while read -r ext; do
      $DST_CMD --install-extension "$ext" 2>&1 | tail -1
    done
  else
    echo "No extensions selected."
  fi
else
  echo "Extensions are in sync."
fi

# ── Settings ──────────────────────────────────────────────────────────────────
echo "\n── Settings ($src_label → $dst_label) ──────────────────────────────────────"

python3 - "$SRC_SETTINGS" "$DST_SETTINGS" > /tmp/sync_settings_diff.txt << 'PYEOF'
import json, sys

def strip_comments(s):
    out, i, n = [], 0, len(s)
    in_str = False
    while i < n:
        c = s[i]
        if in_str:
            if c == '\\' and i + 1 < n:
                out.append(c); out.append(s[i+1]); i += 2
            else:
                if c == '"': in_str = False
                out.append(c); i += 1
        else:
            if c == '"':
                in_str = True; out.append(c); i += 1
            elif c == '/' and i + 1 < n and s[i+1] == '/':
                while i < n and s[i] != '\n': i += 1
            elif c == '/' and i + 1 < n and s[i+1] == '*':
                i += 2
                while i < n - 1 and not (s[i] == '*' and s[i+1] == '/'): i += 1
                i += 2
            else:
                out.append(c); i += 1
    return ''.join(out)

def load(path):
    with open(path) as f:
        return json.loads(strip_comments(f.read()), strict=False)

src, dst = load(sys.argv[1]), load(sys.argv[2])

rows = []
for key, sv in src.items():
    ss = json.dumps(sv, ensure_ascii=False)
    if key not in dst:
        rows.append(('[missing]', key, ss[:70], '—'))
    elif dst[key] != sv:
        ds = json.dumps(dst[key], ensure_ascii=False)
        rows.append(('[differs]', key, ss[:70], ds[:70]))

for t, k, s, d in sorted(rows, key=lambda x: x[1]):
    print(f'{t}\t{k}\t{s}\t{d}')
PYEOF

settings_count=$(grep -c . /tmp/sync_settings_diff.txt 2>/dev/null || echo 0)

if [[ $settings_count -gt 0 ]]; then
  selected_settings=$(cat /tmp/sync_settings_diff.txt | \
    fzf --multi \
      --prompt="Apply to $dst_label > " \
      --header="$settings_count settings differ  |  TAB select  CTRL-A all  ENTER confirm  |  status  key  src-value  dst-value" \
      --delimiter=$'\t' \
      --with-nth='1,2,3,4' \
      --height=80% --border \
      --bind='ctrl-a:select-all') || true

  if [[ -n "$selected_settings" ]]; then
    keys=$(echo "$selected_settings" | cut -f2)

    python3 - "$SRC_SETTINGS" "$DST_SETTINGS" "$keys" << 'PYEOF'
import json, sys

def strip_comments(s):
    out, i, n = [], 0, len(s)
    in_str = False
    while i < n:
        c = s[i]
        if in_str:
            if c == '\\' and i + 1 < n:
                out.append(c); out.append(s[i+1]); i += 2
            else:
                if c == '"': in_str = False
                out.append(c); i += 1
        else:
            if c == '"':
                in_str = True; out.append(c); i += 1
            elif c == '/' and i + 1 < n and s[i+1] == '/':
                while i < n and s[i] != '\n': i += 1
            elif c == '/' and i + 1 < n and s[i+1] == '*':
                i += 2
                while i < n - 1 and not (s[i] == '*' and s[i+1] == '/'): i += 1
                i += 2
            else:
                out.append(c); i += 1
    return ''.join(out)

def load(path):
    with open(path) as f:
        return json.loads(strip_comments(f.read()), strict=False)

src = load(sys.argv[1])
dst = load(sys.argv[2])
keys = [k.strip() for k in sys.argv[3].strip().split('\n') if k.strip()]

for key in keys:
    if key in src:
        dst[key] = src[key]
        print(f'  + {key}', file=sys.stderr)

with open(sys.argv[2], 'w') as f:
    json.dump(dst, f, indent=2, ensure_ascii=False)
    f.write('\n')
PYEOF

    echo "Done."
  else
    echo "No settings selected."
  fi
else
  echo "Settings are in sync."
fi
