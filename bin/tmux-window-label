#!/usr/bin/env bash
# Print a tmux window name: manual override, git repo/worktree · branch, or process/dir.
set -euo pipefail

[[ -n ${TMUX:-} ]] || exit 0

manual=$(tmux show -wqv @manual_window_name 2>/dev/null || true)
if [[ -n $manual ]]; then
  printf '%s\n' "$manual"
  exit 0
fi

path=$(tmux display-message -p '#{pane_current_path}')
cmd=$(tmux display-message -p '#{pane_current_command}')

case $cmd in
  zsh|bash|sh|fish|tmux|*-zsh|*-bash)
    if label=$(cd "$path" && command tmux-pane-git-label 2>/dev/null); then
      printf '%s\n' "$label"
      exit 0
    fi
    printf '%s\n' "$(basename "$path")"
    ;;
  *)
    printf '%s\n' "$cmd"
    ;;
esac
