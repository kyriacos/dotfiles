#!/usr/bin/env bash
#
# gwt - git worktree helper
#
# Portable across machines, repos, and editors. Operates on whatever git
# repository the current directory belongs to; no root or repo is hardcoded.
#
# New worktrees are created under a parent directory resolved as:
#     --path <dir>  >  $GWT_WORKTREE_DIR  >  parent of the main worktree
# So by default a worktree lands as a sibling of the repo (one level up), named
# <repo>-<branch>, e.g. /code/backend -> /code/backend-feature. Relative parents
# resolve against the current directory and are created if missing. Slashes in
# the branch become dashes in the directory name.
#
# After creating a worktree, gwt can run the repo's own setup commands from
# .cursor/worktrees.json ("setup-worktree": [...]), substituting
# $ROOT_WORKTREE_PATH for the main worktree path. Because those commands come
# from the repository (untrusted in a clone you didn't write), gwt asks before
# running them unless --run-setup / --no-setup or $GWT_RUN_SETUP=1|0 decides.
# With no such config, it falls back to copying a top-level .env when present.
#
# Auto-cd: a script cannot change its parent shell's directory, so the
# create/switch verbs print the worktree path to stdout instead. Either run
# `cd "$(gwt new my-feature)"`, or drop this wrapper into your shell rc so
# `gwt new|from|co|search` lands you in the worktree directly.
#
# `from` and `co` with no arguments open an fzf branch picker inside the script.
# The script signals the result with a GWT_POPULATE: prefix on stdout; the
# wrapper writes that into the zsh line buffer (print -z) so you can review the
# command, add flags like --no-setup or -p <dir>, then hit Enter when ready.
# Only print -z is shell-specific; the picker logic lives in the script itself.
#
#   gwt() {
#     case "$1" in
#       new|from|co|checkout|search|pick)
#         local out; out=$(command gwt "$@") || return
#         if [[ $out == GWT_POPULATE:* ]]; then
#           print -z "${out#GWT_POPULATE:}"
#         else
#           builtin cd "${out##*$'\n'}" && command gwt ls
#         fi ;;
#       *) command gwt "$@" ;;
#     esac
#   }
#
# Zsh completions: copy the block below into a file called _gwt on your fpath
# (e.g. ~/.zsh/completions/_gwt), then run `compinit` or open a new shell.
# Completes subcommands, existing worktree names, and local branch names.
#
#   #compdef gwt
#   _gwt() {
#     local state
#     _arguments -C '1: :->cmd' '*:: :->args'
#     case $state in
#       cmd)
#         local -a commands
#         commands=(
#           'new:Create a worktree on a new branch'
#           'from:Create a worktree for an existing branch'
#           'co:Switch to or create a worktree'
#           'checkout:Switch to or create a worktree'
#           'rm:Remove a worktree'
#           'remove:Remove a worktree'
#           'search:Fuzzy-search worktrees with fzf'
#           'pick:Fuzzy-search worktrees with fzf'
#           'clean:Multi-select stale worktrees to remove'
#           'ls:List worktrees'
#           'list:List worktrees'
#           'prune:Prune stale worktree metadata'
#           'st:git status for the current worktree'
#           'status:git status for the current worktree'
#           'log:git log for the current worktree'
#         )
#         _describe 'command' commands
#         ;;
#       args)
#         case $words[1] in
#           co|checkout)
#             local -a worktrees branches
#             worktrees=( ${(f)"$(git worktree list --porcelain 2>/dev/null | awk '/^branch /{sub("refs/heads/",""); print $2}')"} )
#             branches=( ${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"} )
#             _describe 'worktree' worktrees
#             _describe 'branch' branches ;;
#           rm|remove)
#             local -a worktrees
#             worktrees=( ${(f)"$(git worktree list --porcelain 2>/dev/null | awk '/^branch /{sub("refs/heads/",""); print $2}')"} )
#             _describe 'worktree' worktrees
#             _arguments '-f[discard uncommitted changes]' '--force[discard uncommitted changes]' \
#               '(-d --delete-branch)'{-d,--delete-branch}'[also delete the local branch]' \
#               '-D[also force-delete the local branch]' ;;
#           from)
#             local -a branches
#             branches=( ${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"} )
#             _describe 'branch' branches
#             _arguments '(-p --path)'{-p,--path}'[parent dir]:dir:_files -/' \
#               '--run-setup[run setup without prompting]' '--no-setup[skip setup]' ;;
#           new)
#             _arguments '1:branch name: ' '2:base branch or commit: ' \
#               '(-p --path)'{-p,--path}'[parent dir]:dir:_files -/' \
#               '(-u --push --set-upstream)'{-u,--push,--set-upstream}'[push -u to set upstream]' \
#               '--no-push[skip upstream push]' \
#               '--run-setup[run setup without prompting]' '--no-setup[skip setup]' ;;
#         esac ;;
#     esac
#   }
#   _gwt

set -euo pipefail

prog=${0##*/}

# Colors, only when stderr is a terminal and NO_COLOR is unset. They are
# applied to diagnostics and help only -- never to the path on stdout, which
# must stay plain so `cd "$(gwt new foo)"` works.
if [[ -t 2 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'; c_bold=$'\033[1m'; c_dim=$'\033[2m'
  c_red=$'\033[31m';  c_grn=$'\033[32m'; c_ylw=$'\033[33m'
  c_blu=$'\033[34m';  c_cyn=$'\033[36m'
else
  c_reset=''; c_bold=''; c_dim=''
  c_red='';   c_grn='';  c_ylw=''
  c_blu='';   c_cyn=''
fi

# Shared awk program that turns the TSV emitted by gather_worktrees
# (path<TAB>hash<TAB>branch<TAB>state<TAB>current) into a colored listing.
# MODE=ls produces an aligned table; MODE=fzf produces "<display>\t<path>" so a
# picker can show the colored display (--with-nth=1) and recover the raw path.
# State colors: active=green, local-only=blue, gone/merged/missing=red (stale),
# detached=yellow, bare=dim. Stale rows also tag the branch with its state.
read -r -d '' WT_AWK <<'AWK' || true
function color(s) {
  if (s == "active")  return grn
  if (s == "local")   return blu
  if (s == "gone" || s == "missing") return red
  if (s == "detached") return ylw
  return dim
}
function label(s) { return (s == "local") ? "local-only" : s }
function stale(s) { return (s == "gone" || s == "missing") }
function rawbranch(br, s) {
  if (br == "")       return "(" label(s) ")"
  if (stale(s))       return "[" br "] (" label(s) ")"
  return "[" br "]"
}
{
  n++
  wt_path[n] = $1; wt_hash[n] = $2; wt_br[n] = $3; wt_st[n] = $4; wt_cur[n] = ($5 == "1")
  braw[n] = rawbranch($3, $4)
  if (length(braw[n]) > maxb) maxb = length(braw[n])
  if (length($1)     > maxp) maxp = length($1)
}
END {
  for (i = 1; i <= n; i++) {
    c    = color(wt_st[i])
    mark = wt_cur[i] ? (cyn "* " reset) : "  "
    bcol = c sprintf("%-*s", maxb, braw[i]) reset
    hcol = dim wt_hash[i] reset
    if (MODE == "fzf") {
      pcol = wt_cur[i] ? (bold cyn wt_path[i] reset) : (bold wt_path[i] reset)
      printf "%s%s  %s  %s\t%s\n", mark, bcol, pcol, hcol, wt_path[i]
    } else {
      pp   = sprintf("%-*s", maxp, wt_path[i])
      pcol = wt_cur[i] ? (bold cyn pp reset) : (bold pp reset)
      printf "%s%s  %s  %s\n", mark, bcol, pcol, hcol
    }
  }
}
AWK

# Diagnostics go to stderr so that stdout stays clean: `new`/`co` print only
# the resulting worktree path, making `cd "$(gwt new foo)"` work.
err() { printf '%s\n' "$*" >&2; }
die() { err "${c_red}$prog:${c_reset} $*"; exit 1; }

usage() {
  cat >&2 <<EOF
${c_bold}$prog${c_reset} - git worktree helper (operates on the current repo)

${c_bold}Usage:${c_reset}
  ${c_cyn}$prog new${c_reset} <name> [base] ${c_ylw}[-p <dir>]${c_reset}  Create a worktree on a NEW branch <name>,
                            branched from [base] (default: current HEAD), push
                            with -u to set upstream (skip with --no-push), then
                            run repo setup. Prints the new worktree path.
  ${c_cyn}$prog from${c_reset} <branch> ${c_ylw}[-p <dir>]${c_reset}      Create a worktree for an EXISTING branch,
                            then run repo setup. Prints the new worktree path.
  ${c_cyn}$prog co${c_reset} <name> ${c_ylw}[-p <dir>]${c_reset}          Switch to the worktree for <name> if it
                            exists (prints its path); otherwise create it from
                            branch <name>, like 'from'.
  ${c_cyn}$prog rm${c_reset} [name] ${c_ylw}[-f] [-d|-D]${c_reset}  Remove a worktree. With no name, removes the one
                            you are standing in. -f/--force discards changes.
                            -d also deletes its local branch (-D force-deletes);
                            without -d the branch is kept.
  ${c_cyn}$prog search${c_reset}              Fuzzy-search worktrees with fzf and print the chosen path.
  ${c_cyn}$prog clean${c_reset}               List worktrees (stale ones in red), multi-select with fzf,
                            then remove the chosen worktrees and their stale branches.
  ${c_cyn}$prog ls${c_reset}                  List worktrees for this repo.
  ${c_cyn}$prog prune${c_reset}               Prune stale worktree metadata.
  ${c_cyn}$prog st${c_reset} [git-args...]    git status (short) for the current worktree.
  ${c_cyn}$prog log${c_reset} [git-args...]   git log (oneline graph) for the current worktree.
  ${c_cyn}$prog -h | --help${c_reset}         Show this help.

${c_bold}Worktree location${c_reset} (new/co), highest precedence first:
  ${c_ylw}-p, --path <dir>${c_reset}          Parent dir for this invocation.
  ${c_ylw}\$GWT_WORKTREE_DIR${c_reset}         Parent dir default (if set).
  ${c_ylw}<repo>/..${c_reset}                 Fallback: parent of the main worktree (sibling of the repo).
The worktree is created at <parent>/<repo>-<name>; relative parents are made if absent.

${c_bold}Upstream${c_reset} (new only):
  After creating the branch, gwt runs ${c_ylw}git push -u <remote> <name>${c_reset} so a later
  plain ${c_ylw}git push${c_reset} works. The remote is inherited from [base] or defaults to
  origin. Override with:
  ${c_ylw}--no-push${c_reset} / ${c_ylw}--push${c_reset} (-u)     Skip (or force) without using \$GWT_PUSH_UPSTREAM.
  ${c_ylw}\$GWT_PUSH_UPSTREAM${c_reset}=1|0        Default is push (1); set 0 to skip by default.
  A failed push is non-fatal; the worktree is still created.

${c_bold}Repo setup${c_reset} (.cursor/worktrees.json setup-worktree[-unix|-windows] commands):
  These come from the repo, so gwt asks before running them. Override with:
  ${c_ylw}--run-setup${c_reset} / ${c_ylw}--no-setup${c_reset}      Run (or skip) without prompting.
  ${c_ylw}\$GWT_RUN_SETUP${c_reset}=1|0           Default decision when no flag is given.

${c_bold}Worktree states${c_reset} (shown by ls/search/clean):
  ${c_grn}[branch]${c_reset}                  Active: live upstream with unmerged work.
  ${c_blu}[branch] (local-only)${c_reset}     Never pushed (no upstream). Kept; not treated as stale.
  ${c_red}[branch] (gone)${c_reset}           Upstream was deleted (e.g. merged PR). ${c_red}Stale.${c_reset}
  ${c_red}(missing)${c_reset}                 Worktree directory is gone (prunable). ${c_red}Stale.${c_reset}
  ${c_ylw}(detached)${c_reset}                Not on a branch. ${c_ylw}(bare)${c_reset} is the main repo.

${c_bold}Notes:${c_reset}
  ${c_dim}- A script cannot change your shell's directory. To jump into a new worktree:
        cd "\$($prog new my-feature)"
    or add the wrapper function from the gwt header comments to your shell rc.
  - Branch names with slashes become dashes in the directory name.${c_reset}
EOF
}

# Resolve the repo's main worktree path (first entry of `worktree list`).
main_worktree() {
  git worktree list --porcelain | awk '/^worktree /{print $2; exit}'
}

# Resolve the destination worktree path from a name and optional parent.
# Echoes the absolute-ish destination; creates the parent if needed.
resolve_dest() {
  local name=$1 parent=${2:-} root repo
  root=$(main_worktree)
  repo=$(basename "$root")
  # Default parent: one level up from the main worktree, so new worktrees land
  # as siblings of the repo regardless of the current directory.
  parent=${parent:-${GWT_WORKTREE_DIR:-$(dirname "$root")}}
  [[ $parent != /* ]] && parent="$PWD/$parent"
  mkdir -p "$parent" || die "cannot create parent dir: $parent"
  parent=$(cd "$parent" && pwd)  # canonicalize away ./ and ../ for clean output
  # Prefix with the repo name so sibling worktrees stay identifiable, e.g.
  # repo "backend" + branch "feature" -> backend-feature.
  printf '%s/%s-%s\n' "$parent" "$repo" "${name//\//-}"
}

# Echo the branch checked out in the worktree at $1 (empty if detached).
worktree_branch() {
  git worktree list --porcelain | awk -v t="$1" '
    /^worktree /{ p = $2 }
    /^branch /{ if (p == t) { b = $2; sub("refs/heads/", "", b); print b } }
  '
}

# Classify a local branch's state from its upstream. Echoes one of:
#   gone   - had an upstream that is now deleted (typical of a merged PR).
#   local  - never pushed; no upstream at all (work-in-progress, NOT stale).
#   active - has a live upstream.
# "gone" is deliberately distinct from "local": a branch you never pushed has no
# upstream, so it is reported local (safe), never gone. We do NOT infer "merged"
# from ancestry: a branch that is simply behind the default branch (idle or just
# created) is indistinguishable from a merged one, so that test produced false
# positives. A genuinely merged PR shows up as "gone" once its remote branch is
# deleted, which is the signal we trust.
branch_state() {
  local br=$1 up track
  track=$(git for-each-ref --format='%(upstream:track)' "refs/heads/$br" 2>/dev/null)
  [[ $track == *gone* ]] && { printf gone; return 0; }
  up=$(git for-each-ref --format='%(upstream)' "refs/heads/$br" 2>/dev/null)
  [[ -z $up ]] && { printf local; return 0; }
  printf active; return 0
}

# Emit one TSV record (path<TAB>hash<TAB>branch<TAB>state<TAB>current) for a
# parsed worktree. state is bare|missing|detached or a branch_state value.
_emit_wt() {
  local path=$1 head=$2 branch=$3 detached=$4 bare=$5 prunable=$6 cur=$7
  [[ -z $path ]] && return 0
  local state cur_flag=0
  [[ $path == "$cur" ]] && cur_flag=1
  if   [[ $bare == 1 ]];                        then state=bare
  elif [[ ! -e $path || $prunable == 1 ]];      then state=missing
  elif [[ $detached == 1 || -z $branch ]];      then state=detached
  else state=$(branch_state "$branch"); fi
  printf '%s\t%s\t%s\t%s\t%s\n' "$path" "${head:0:7}" "$branch" "$state" "$cur_flag"
}

# Emit a TSV record for every worktree in this repo. Consumed by ls/search/clean
# (formatted via WT_AWK) and by clean's removal logic (state lookup by path).
gather_worktrees() {
  local cur line
  cur=$(git rev-parse --show-toplevel 2>/dev/null || true)
  local path="" head="" branch="" detached=0 bare=0 prunable=0
  while IFS= read -r line; do
    case $line in
      "worktree "*)
        _emit_wt "$path" "$head" "$branch" "$detached" "$bare" "$prunable" "$cur"
        path=${line#worktree }; head=""; branch=""; detached=0; bare=0; prunable=0 ;;
      "HEAD "*)     head=${line#HEAD } ;;
      "branch "*)   branch=${line#branch refs/heads/} ;;
      detached)     detached=1 ;;
      bare)         bare=1 ;;
      "prunable "*) prunable=1 ;;
    esac
  done < <(git worktree list --porcelain)
  _emit_wt "$path" "$head" "$branch" "$detached" "$bare" "$prunable" "$cur"
}

# Find the worktree path for a name, matching its branch or directory name.
resolve_worktree() {
  git worktree list --porcelain | awk -v t="$1" '
    function flush() {
      if (p != "") { b = p; sub(".*/", "", b); if (br == t || b == t) print p }
      p = ""; br = ""
    }
    /^worktree /{ flush(); p = $2 }
    /^branch /{ br = $2; sub("refs/heads/", "", br) }
    END { flush() }
  ' | head -1
}

# Map $GWT_RUN_SETUP to an explicit yes/no, or empty if unset/unrecognized.
setup_env_decision() {
  case ${GWT_RUN_SETUP:-} in
    1|true|TRUE|yes|YES|on|ON)   printf yes ;;
    0|false|FALSE|no|NO|off|OFF) printf no ;;
    *)                           printf '' ;;
  esac
}

# Ask interactively whether to run the repo's setup commands; echoes yes/no.
# Prompt text goes to stderr (stdout is reserved for the worktree path) and the
# answer is read from the terminal, so it works under `cd "$(gwt new ..)"` too.
# With no terminal and no explicit decision, defaults to no.
prompt_setup() {
  local cmds=$1 ans c
  if [[ ! -r /dev/tty ]]; then
    err "${c_ylw}.cursor/worktrees.json defines setup commands, but there is no terminal to confirm; skipping.${c_reset}"
    err "${c_dim}Re-run with --run-setup (or GWT_RUN_SETUP=1) to execute them.${c_reset}"
    printf no; return
  fi
  err "${c_ylw}This repo's .cursor/worktrees.json wants to run these setup commands:${c_reset}"
  while IFS= read -r c; do [[ -n $c ]] && err "  ${c_dim}\$ $c${c_reset}"; done <<<"$cmds"
  printf '%sRun them? [y/N] %s' "$c_ylw" "$c_reset" >&2
  read -r ans </dev/tty || ans=''
  case $ans in y|Y|yes|YES) printf yes ;; *) printf no ;; esac
}

# Run the repo's setup-worktree commands in $1 (the new worktree), if any and
# if permitted. Permission precedence: explicit decision arg ($3, from a flag)
# > $GWT_RUN_SETUP > interactive confirmation. The commands come from a file in
# the repository, so they are treated as untrusted and never run without
# consent. With no setup config, falls back to copying a top-level .env.
run_setup() {
  local new_path=$1 root=$2 decision=${3:-} cfg="$2/.cursor/worktrees.json"

  local cmds=""
  if [[ -f $cfg ]] && command -v python3 >/dev/null 2>&1; then
    cmds=$(ROOT_WORKTREE_PATH="$root" python3 - "$cfg" <<'PY'
import json, os, sys
cfg = json.load(open(sys.argv[1]))
root = os.environ["ROOT_WORKTREE_PATH"]

def pick_setup(cfg):
    if sys.platform == "win32":
        keys = ("setup-worktree-windows", "setup-worktree")
    else:
        keys = ("setup-worktree-unix", "setup-worktree")
    for k in keys:
        v = cfg.get(k)
        if v is not None:
            return v
    return None

def normalize_commands(v):
    if v is None:
        return []
    if isinstance(v, str):
        return [v]
    if isinstance(v, list):
        return [c for c in v if isinstance(c, str)]
    return [str(v)]

for c in normalize_commands(pick_setup(cfg)):
    print(c.replace("$ROOT_WORKTREE_PATH", root))
PY
)
  fi

  if [[ -n $cmds ]]; then
    [[ -z $decision ]] && decision=$(setup_env_decision)
    [[ -z $decision ]] && decision=$(prompt_setup "$cmds")
    if [[ $decision != yes ]]; then
      err "${c_dim}Skipped setup-worktree commands.${c_reset}"
      return
    fi
    err "${c_dim}Running setup-worktree from .cursor/worktrees.json ...${c_reset}"
    while IFS= read -r cmd; do
      [[ -z $cmd ]] && continue
      err "  ${c_dim}\$ $cmd${c_reset}"
      ( cd "$new_path" && ROOT_WORKTREE_PATH="$root" bash -c "$cmd" >&2 ) \
        || err "  ${c_ylw}(setup step failed, continuing):${c_reset} $cmd"
    done <<<"$cmds"
    return
  fi

  # Fallback: copy a top-level .env if the repo has one.
  if [[ -f "$root/.env" && ! -e "$new_path/.env" ]]; then
    cp "$root/.env" "$new_path/.env"
    err "${c_dim}Copied .env from main worktree.${c_reset}"
  fi
}

# Echo the branch name for a symbolic ref like HEAD, or the ref unchanged.
resolve_base_branch() {
  local base=$1
  if [[ $base == HEAD ]]; then
    git symbolic-ref -q --short HEAD 2>/dev/null || printf HEAD
  else
    printf '%s' "$base"
  fi
}

# Echo the remote to push a new branch to: inherit from [base] when it is a
# local branch, else fall back to origin when that remote exists.
resolve_push_remote() {
  local base=$1 br remote
  br=$(resolve_base_branch "$base")
  if git show-ref --verify --quiet "refs/heads/$br" 2>/dev/null; then
    remote=$(git config "branch.$br.remote" 2>/dev/null)
  fi
  remote=${remote:-origin}
  git remote get-url "$remote" &>/dev/null && printf '%s' "$remote"
}

# Map $GWT_PUSH_UPSTREAM to an explicit yes/no, or empty if unset.
push_upstream_env_decision() {
  case ${GWT_PUSH_UPSTREAM:-} in
    1|true|TRUE|yes|YES|on|ON)   printf yes ;;
    0|false|FALSE|no|NO|off|OFF) printf no ;;
    *)                           printf '' ;;
  esac
}

# Push a new branch with -u so the first plain `git push` works later. Failure
# is non-fatal: the worktree is already created. Skipped when decision is no.
push_upstream() {
  local path=$1 name=$2 base=$3 decision=${4:-}
  [[ -z $decision ]] && decision=$(push_upstream_env_decision)
  [[ -z $decision ]] && decision=yes
  [[ $decision == no ]] && return 0

  local remote
  remote=$(resolve_push_remote "$base")
  if [[ -z $remote ]]; then
    err "${c_ylw}No remote configured; skipping upstream push.${c_reset}"
    err "${c_dim}Push later with: git push -u origin $name${c_reset}"
    return 0
  fi

  err "${c_dim}Setting upstream: git push -u $remote $name ...${c_reset}"
  if git -C "$path" push -u "$remote" "$name" >&2; then
    err "${c_grn}Upstream set:${c_reset} $remote/$name"
  else
    err "${c_ylw}Could not push upstream (offline or no permission?).${c_reset}"
    err "${c_dim}Worktree is ready; push later with: git push -u $remote $name${c_reset}"
  fi
}

# Parse positionals + optional flags out of "$@". Sets globals parsed_pos
# (array), parsed_path, parsed_setup, and parsed_push (""/yes/no). Used by new/from/co.
parse_args() {
  parsed_pos=(); parsed_path=""; parsed_setup=""; parsed_push=""
  while [[ $# -gt 0 ]]; do
    case $1 in
      -p|--path)                         parsed_path=${2:-}; shift 2 ;;
      --path=*)                          parsed_path=${1#*=}; shift ;;
      --run-setup|--yes|-y)              parsed_setup=yes; shift ;;
      --no-setup)                        parsed_setup=no;  shift ;;
      --push|-u|--set-upstream)          parsed_push=yes; shift ;;
      --no-push)                         parsed_push=no;  shift ;;
      -*)                                die "unknown flag: $1" ;;
      *)                                 parsed_pos+=("$1"); shift ;;
    esac
  done
}

cmd_new() {
  parse_args "$@"
  local name=${parsed_pos[0]:-} base=${parsed_pos[1]:-HEAD}
  [[ -n $name ]] || { usage; exit 1; }

  local root path
  root=$(main_worktree)
  path=$(resolve_dest "$name" "$parsed_path")
  [[ -e $path ]] && die "path already exists: $path"

  git worktree add -b "$name" "$path" "$base" >&2
  push_upstream "$path" "$name" "$base" "$parsed_push"
  run_setup "$path" "$root" "$parsed_setup"
  err "${c_grn}Created worktree:${c_reset} ${c_bold}$path${c_reset}"
  printf '%s\n' "$path"
}

# Open an fzf picker over local branches. On success, prints
# "GWT_POPULATE:gwt <verb> <branch>" to stdout and exits 0 so the shell wrapper
# can write that string into the line buffer instead of cd-ing.
pick_branch() {
  local verb=$1
  command -v fzf >/dev/null 2>&1 || die "fzf is required for the interactive picker (brew install fzf)"
  local pick
  pick=$(format_branches \
    | fzf --prompt="${verb}> " \
          --height=50% --reverse --ansi \
          --delimiter=$'\t' --with-nth=1 \
          --header=$'red=upstream gone  blue=local-only  green=active' \
          --preview='git log --oneline --graph --decorate --color=always -n 10 {2}' \
          --preview-window=right:50%:wrap \
          2>/dev/tty) || exit 0
  pick=${pick##*$'\t'}
  printf 'GWT_POPULATE:gwt %s %s\n' "$verb" "$pick"
  exit 0
}

cmd_from() {
  parse_args "$@"
  local branch=${parsed_pos[0]:-}
  [[ -z $branch ]] && pick_branch from

  local root path
  root=$(main_worktree)
  path=$(resolve_dest "$branch" "$parsed_path")
  [[ -e $path ]] && die "path already exists: $path"

  git worktree add "$path" "$branch" >&2
  run_setup "$path" "$root" "$parsed_setup"
  err "${c_grn}Created worktree:${c_reset} ${c_bold}$path${c_reset}"
  printf '%s\n' "$path"
}

# Switch to an existing worktree if one matches <name>; otherwise create one
# from the existing branch (delegates to `from`). Prints the worktree path.
cmd_co() {
  parse_args "$@"
  local name=${parsed_pos[0]:-}
  [[ -z $name ]] && pick_branch co

  local existing
  existing=$(resolve_worktree "$name")
  if [[ -n $existing ]]; then
    err "${c_cyn}Switching to existing worktree:${c_reset} ${c_bold}$existing${c_reset}"
    printf '%s\n' "$existing"
    return
  fi

  err "${c_ylw}No worktree for '$name' yet;${c_reset} creating one from branch '$name'."
  cmd_from "$@"
}

cmd_rm() {
  local force=() target="" del_branch=""
  for arg in "$@"; do
    case $arg in
      -f|--force)         force=(--force) ;;
      -d|--delete-branch) del_branch=-d ;;
      -D)                 del_branch=-D ;;
      *)                  target=$arg ;;
    esac
  done

  local root path branch
  root=$(main_worktree)
  if [[ -n $target ]]; then
    path=$(resolve_worktree "$target")
    [[ -n $path ]] || die "no worktree matching '$target' (see '$prog ls')"
  else
    path=$(git rev-parse --show-toplevel)
  fi

  [[ $path == "$root" ]] && die "refusing to remove the main worktree"

  # Capture the branch before removal; afterwards the worktree is gone.
  branch=$(worktree_branch "$path")

  # If standing inside the target, step out first so the dir can be removed.
  [[ $PWD == "$path"* ]] && cd "$root"
  git worktree remove "${force[@]}" "$path"
  err "${c_grn}Removed worktree:${c_reset} ${c_bold}$path${c_reset}"

  if [[ -n $del_branch ]]; then
    if [[ -z $branch ]]; then
      err "${c_ylw}Worktree was detached; no branch to delete.${c_reset}"
    elif git -C "$root" branch "$del_branch" "$branch" >&2; then
      err "${c_grn}Deleted branch:${c_reset} ${c_bold}$branch${c_reset}"
    else
      err "${c_ylw}Could not delete branch '$branch'; rerun with -D to force.${c_reset}"
    fi
  elif [[ -n $branch ]]; then
    err "${c_dim}Branch '$branch' kept. Add -d (or -D to force) to delete it too next time.${c_reset}"
  fi
}

# One-line color legend explaining each worktree state.
legend() {
  printf '%sstates:%s %sactive%s  %slocal-only%s  %sgone%s  %smissing%s  %sdetached%s\n' \
    "$c_dim" "$c_reset" \
    "$c_grn" "$c_reset" "$c_blu" "$c_reset" "$c_red" "$c_reset" \
    "$c_red" "$c_reset" "$c_ylw" "$c_reset"
}

# Render gather_worktrees output through WT_AWK in the given MODE (ls|fzf).
format_worktrees() {
  awk -F'\t' -v MODE="$1" \
    -v reset="$c_reset" -v bold="$c_bold" -v dim="$c_dim" \
    -v grn="$c_grn" -v cyn="$c_cyn" -v ylw="$c_ylw" -v blu="$c_blu" -v red="$c_red" \
    "$WT_AWK"
}

# Emit "<colored display>\t<branch>" for every local branch, colored by the same
# state scheme as the worktree listings (this mirrors branch_state's rule, run
# in a single for-each-ref so opening the picker stays fast):
#   red (gone) = upstream deleted, blue = local-only (no upstream), green = active.
format_branches() {
  local name up track c tag
  while IFS=$'\t' read -r name up track; do
    [[ -z $name ]] && continue
    if   [[ $track == *gone* ]]; then c=$c_red; tag=" (gone)"
    elif [[ -z $up ]];           then c=$c_blu; tag=""
    else                              c=$c_grn; tag=""
    fi
    printf '%s%s%s%s\t%s\n' "$c" "$name" "$tag" "$c_reset" "$name"
  done < <(git for-each-ref --format='%(refname:short)%09%(upstream)%09%(upstream:track)' refs/heads 2>/dev/null)
}

cmd_search() {
  command -v fzf >/dev/null 2>&1 || die "fzf is required for 'search' (brew install fzf)"

  local pick
  # Colored "display\tpath"; fzf shows the display, we recover the path.
  pick=$(gather_worktrees | format_worktrees fzf \
    | fzf --prompt="worktree> " \
          --ansi \
          --height=40% \
          --reverse \
          --delimiter=$'\t' \
          --with-nth=1 \
          --preview='git -C {2} log --oneline --graph --decorate --color=always -n 10 2>/dev/null' \
          --preview-window=right:50%:wrap \
          2>/dev/tty) || return 0

  printf '%s\n' "${pick##*$'\t'}"
}

cmd_ls() {
  local records
  records=$(gather_worktrees)
  printf '%s\n' "$records" | format_worktrees ls
  # Only explain the colors when something stale is present, so the auto-ls
  # after each cd stays quiet for the common all-active case.
  printf '%s\n' "$records" | grep -qE $'\t(gone|missing)\t' && legend || true
}

# Remove a single worktree at $1 (root $2, state $3). Refuses the main worktree
# and never force-removes a dirty tree. The local branch is deleted only for
# confirmed-stale states (gone/merged/missing); otherwise it is kept.
remove_one() {
  local path=$1 root=$2 state=$3 branch
  [[ $path == "$root" ]] && { err "${c_ylw}Skipped main worktree:${c_reset} $path"; return; }
  branch=$(worktree_branch "$path")
  [[ $PWD == "$path"* ]] && cd "$root"

  if [[ ! -e $path || $state == missing ]]; then
    git worktree remove --force "$path" >/dev/null 2>&1 || git worktree prune >/dev/null 2>&1 || true
    err "${c_grn}Pruned missing worktree:${c_reset} ${c_bold}$path${c_reset}"
  elif git worktree remove "$path" 2>/dev/null; then
    err "${c_grn}Removed worktree:${c_reset} ${c_bold}$path${c_reset}"
  else
    err "${c_ylw}Could not remove (uncommitted changes?):${c_reset} $path"
    err "${c_dim}  Remove it explicitly with: $prog rm '$branch' -f${c_reset}"
    return
  fi

  if [[ -n $branch ]]; then
    case $state in
      gone|missing)
        if git -C "$root" branch -D "$branch" >/dev/null 2>&1; then
          err "${c_grn}Deleted branch:${c_reset} ${c_bold}$branch${c_reset}"
        fi ;;
      *) err "${c_dim}Kept branch '$branch' (not stale).${c_reset}" ;;
    esac
  fi
}

# List all worktrees (stale ones in red), let the user multi-select with fzf,
# then remove the chosen worktrees and clean up their stale branches.
cmd_clean() {
  local root records
  root=$(main_worktree)
  records=$(gather_worktrees)
  [[ -z $records ]] && { err "${c_dim}No worktrees.${c_reset}"; return; }

  if ! command -v fzf >/dev/null 2>&1; then
    err "${c_ylw}fzf not found; showing report only (red = stale, removable).${c_reset}"
    printf '%s\n' "$records" | format_worktrees ls
    legend
    err "${c_dim}Install fzf for interactive cleanup, or remove with '$prog rm <name> -d'.${c_reset}"
    return
  fi

  local picks
  picks=$(printf '%s\n' "$records" | format_worktrees fzf \
    | fzf --multi \
          --ansi \
          --prompt="clean> " \
          --header=$'TAB select / ENTER confirm  |  red=stale (gone/missing)  blue=local-only  green=active' \
          --height=60% \
          --reverse \
          --delimiter=$'\t' \
          --with-nth=1 \
          --preview='git -C {2} log --oneline --graph --decorate --color=always -n 10 2>/dev/null' \
          --preview-window=right:50%:wrap \
          2>/dev/tty) || return 0
  [[ -z $picks ]] && { err "${c_dim}Nothing selected.${c_reset}"; return; }

  local line path state
  while IFS= read -r line; do
    [[ -z $line ]] && continue
    path=${line##*$'\t'}
    state=$(printf '%s\n' "$records" | awk -F'\t' -v p="$path" '$1==p{print $4; exit}')
    remove_one "$path" "$root" "$state"
  done <<<"$picks"
}

case ${1:-} in
  new)            shift; cmd_new "$@" ;;
  from)           shift; cmd_from "$@" ;;
  co|checkout)    shift; cmd_co "$@" ;;
  rm|remove)      shift; cmd_rm "$@" ;;
  search|pick)    shift; cmd_search "$@" ;;
  clean)          shift; cmd_clean "$@" ;;
  ls|list)        shift; cmd_ls "$@" ;;
  prune)          shift; git worktree prune "$@" ;;
  st|status)      shift; git status -sb "$@" ;;
  log)            shift; git log --oneline --graph --decorate -n 20 "$@" ;;
  -h|--help|help) usage ;;
  "")             usage; exit 1 ;;
  *)              die "unknown command: $1 (try '$prog --help')" ;;
esac
