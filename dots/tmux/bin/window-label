#!/usr/bin/env bash
# Print a tmux window name: manual override, git repo · branch, or process/dir.
set -euo pipefail

[[ -n ${TMUX:-} ]] || exit 0

manual=$(tmux show -wqv @manual_window_name 2>/dev/null || true)
if [[ -n $manual ]]; then
  printf '%s\n' "$manual"
  exit 0
fi

path=$(tmux display-message -p '#{pane_current_path}')
cmd=$(tmux display-message -p '#{pane_current_command}')

command context-label "$path" "$cmd"
