#!/usr/bin/env bash
# Set the current (or -t) pane title from pane-label (no-op if unchanged).
set -euo pipefail
# shellcheck source=_lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"

[[ -n ${TMUX:-} ]] || exit 0

target=${1:-}
label=$("$TMUX_BIN/pane-label" ${target:+"$target"} 2>/dev/null) || exit 0
[[ -z $label ]] && exit 0

if [[ -n $target ]]; then
  current=$(tmux display-message -t "$target" -p '#{pane_title}')
  [[ $current == "$label" ]] && exit 0
  tmux select-pane -t "$target" -T "$label"
else
  current=$(tmux display-message -p '#{pane_title}')
  [[ $current == "$label" ]] && exit 0
  tmux select-pane -T "$label"
fi
