#!/usr/bin/env bash
# Print a pane title from its cwd + command (see context-label).
set -euo pipefail
# shellcheck source=_lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"

[[ -n ${TMUX:-} ]] || exit 0

target=${1:-}
if [[ -n $target ]]; then
  path=$(tmux display-message -t "$target" -p '#{pane_current_path}')
  cmd=$(tmux display-message -t "$target" -p '#{pane_current_command}')
else
  path=$(tmux display-message -p '#{pane_current_path}')
  cmd=$(tmux display-message -p '#{pane_current_command}')
fi

"$TMUX_BIN/context-label" "$path" "$cmd"
