#!/usr/bin/env bash
# Print a label from cwd + command: git repo · branch, process, or dir basename.
set -euo pipefail

path=${1:?}
cmd=${2:?}

case $cmd in
  zsh|bash|sh|fish|tmux|*-zsh|*-bash)
    if label=$(cd "$path" && command pane-git-label 2>/dev/null); then
      printf '%s\n' "$label"
      exit 0
    fi
    printf '%s\n' "$(basename "$path")"
    ;;
  *)
    printf '%s\n' "$cmd"
    ;;
esac
