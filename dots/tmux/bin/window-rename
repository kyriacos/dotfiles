#!/usr/bin/env bash
# Rename the current tmux window from window-label (no-op if unchanged).
set -euo pipefail
# shellcheck source=_lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"

[[ -n ${TMUX:-} ]] || exit 0

label=$("$TMUX_BIN/window-label" 2>/dev/null) || exit 0
[[ -z $label ]] && exit 0

current=$(tmux display-message -p '#{window_name}')
[[ $current == "$label" ]] && exit 0

tmux rename-window "$label"
