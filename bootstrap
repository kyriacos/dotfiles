#!/bin/bash
#
# bootstrap installs things.
DOTFILES_ROOT=$HOME/.dotfiles/dots

set -e

echo ''

# Only-step flags (if any are set, only those steps run)
ONLY_NAME=false
ONLY_GITCONFIG=false
ONLY_DOTFILES=false
ONLY_BREW=false
ONLY_OSX=false
ONLY_KARABINER=false
ONLY_NVIM=false
ONLY_TMUX=false
ONLY_ASS=false

# Skip flags (full run only — skips that step)
SKIP_BREW=false
SKIP_OSX=false
SKIP_TMUX=false
SKIP_GITCONFIG=false

# Brew modifiers (apply when running brew, full or --brew-only)
SKIP_MAS=false
SKIP_CASKS=false
FORMULAS_ONLY=false

COMPUTER_NAME=""

info() {
	# shellcheck disable=SC2059
	printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

user() {
	# shellcheck disable=SC2059
	printf "\r  [ \033[0;33m??\033[0m ] $1\n"
}

success() {
	# shellcheck disable=SC2059
	printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail() {
	# shellcheck disable=SC2059
	printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
	echo ''
	exit 1
}

usage() {
	cat <<EOF
Usage: $(basename "$0") [options]

Without any --*-only flag, runs the full setup in order:
  computer name → gitconfig → dotfiles → shell → Xcode tools → Homebrew → osx defaults → karabiner → tmux plugins

Passing one or more --*-only flags runs only those steps (in the order listed):
  --name-only              Set the computer name only
  --gitconfig-only         Set up git config only
  --dotfiles-only          Symlink dotfiles only
  --brew-only              Run Homebrew update/bundle/upgrade only
  --osx-only               Run osx_set_defaults.sh only
  --karabiner-only         Symlink Karabiner config only
  --nvim-only              Symlink Neovim config only
  --tmux-only              Install tmux plugins only

Skip flags (full run only):
  --skip-brew              Skip all Homebrew steps
  --skip-osx               Skip macOS defaults setup
  --skip-tmux              Skip tmux plugin installation
  --skip-gitconfig         Skip git config setup

Brew modifiers (apply to full run or --brew-only):
  --name <name>            Set computer name non-interactively
  --skip-mas               Skip Mac App Store apps
  --skip-casks             Skip cask installations
  --formulas-only          Brew formulas only; skip mas, casks, and vscode extensions

  -h, --help               Show this help message

Examples:
  bootstrap                              Full setup (prompts for computer name)
  bootstrap --name "Kyriacos MBP"        Full setup, set computer name upfront
  bootstrap --brew-only                  Only run Homebrew
  bootstrap --brew-only --skip-mas       Only run Homebrew, skip App Store
  bootstrap --dotfiles-only              Only symlink dotfiles
  bootstrap --karabiner-only             Only symlink Karabiner config
  bootstrap --nvim-only                  Only symlink Neovim config
  bootstrap --osx-only --tmux-only       Only run osx defaults and tmux setup
EOF
	exit 0
}

while [[ $# -gt 0 ]]; do
	case "$1" in
		--name)
			[[ -z "${2-}" ]] && { echo "--name requires a value"; usage; }
			COMPUTER_NAME="$2"; shift 2 ;;
		--name-only)       ONLY_NAME=true; shift ;;
		--gitconfig-only)  ONLY_GITCONFIG=true; shift ;;
		--dotfiles-only)   ONLY_DOTFILES=true; shift ;;
		--brew-only)       ONLY_BREW=true; shift ;;
		--osx-only)        ONLY_OSX=true; shift ;;
		--karabiner-only|--install-karabiner) ONLY_KARABINER=true; shift ;;
		--nvim-only)       ONLY_NVIM=true; shift ;;
		--tmux-only)       ONLY_TMUX=true; shift ;;
		--ass-only)        ONLY_ASS=true; shift ;;
		--skip-brew)       SKIP_BREW=true; shift ;;
		--skip-osx)        SKIP_OSX=true; shift ;;
		--skip-tmux)       SKIP_TMUX=true; shift ;;
		--skip-gitconfig)  SKIP_GITCONFIG=true; shift ;;
		--skip-mas)        SKIP_MAS=true; shift ;;
		--skip-casks)      SKIP_CASKS=true; shift ;;
		--formulas-only)   FORMULAS_ONLY=true; shift ;;
		-h|--help)         usage ;;
		*) echo "Unknown option: $1"; usage ;;
	esac
done

# Determine if we're in "only" mode
ONLY_MODE=false
$ONLY_NAME      && ONLY_MODE=true
$ONLY_GITCONFIG && ONLY_MODE=true
$ONLY_DOTFILES  && ONLY_MODE=true
$ONLY_BREW      && ONLY_MODE=true
$ONLY_OSX       && ONLY_MODE=true
$ONLY_KARABINER && ONLY_MODE=true
$ONLY_NVIM      && ONLY_MODE=true
$ONLY_TMUX      && ONLY_MODE=true
$ONLY_ASS       && ONLY_MODE=true

# --- Functions ---

setup_gitconfig() {
	info 'setup gitconfig'
	if [ -z "$(git config --global --get user.email)" ]; then
		user ' - What is your github author name?'
		read -r user_name
		user ' - What is your github author email?'
		read -r user_email

		git config --global user.name "$user_name"
		git config --global user.email "$user_email"
	elif [ "$(git config --global --get dotfiles.managed)" != "true" ]; then
		user_name="$(git config --global --get user.name)"
		user_email="$(git config --global --get user.email)"
		mv ~/.gitconfig ~/.gitconfig.backup
		success "moved ~/.gitconfig to ~/.gitconfig.backup"
		git config --global user.name "$user_name"
		git config --global user.email "$user_email"
	else
		info "already managed by dotfiles"
	fi
	git config --global include.path ~/.gitconfig.local
	git config --global dotfiles.managed true
	success 'gitconfig'
}

link_file() {
	if [ -e "$2" ]; then
		if [ "$(readlink "$2")" = "$1" ]; then
			success "skipped $1"
			return 0
		else
			mv "$2" "$2.backup"
			success "moved $2 to $2.backup"
		fi
	fi
	ln -sf "$1" "$2"
	success "linked $1 to $2"
}

install_karabiner() {
	if [[ "$(uname)" != "Darwin" ]]; then
		info "skipping Karabiner symlink (not macOS)"
		return 0
	fi
	info "linking Karabiner config"
	mkdir -p "$HOME/.config"
	link_file "$HOME/.dotfiles/karabiner" "$HOME/.config/karabiner"
}

install_nvim() {
	info "linking Neovim config"
	mkdir -p "$HOME/.config"
	link_file "$HOME/.dotfiles/nvim" "$HOME/.config/nvim"
}

install_dotfiles() {
	info 'installing dotfiles'
	find -H "$DOTFILES_ROOT" -maxdepth 1 -name '*' -not -path '*.git*' |
		while read -r src; do
			dst="$HOME/.$(basename "${src}")"
			link_file "$src" "$dst"
		done
}

find_zsh() {
	if command -v zsh >/dev/null 2>&1 && grep "$(command -v zsh)" /etc/shells >/dev/null; then
		command -v zsh
	else
		echo "/bin/zsh"
	fi
}

install_homebrew() {
	info "installing essentials"
	if [[ $(/usr/bin/gcc 2>&1) =~ "no developer tools were found" ]] || [[ ! -x /usr/bin/gcc ]]; then
		echo "Installing Xcode CLI tools"
		xcode-select --install
	fi

	if [[ ! -x /opt/homebrew/bin/brew ]]; then
		info "Installing Homebrew"
		/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
	fi

	BUNDLE_ARGS="--verbose --file=$HOME/.dotfiles/Brewfile"
	if $FORMULAS_ONLY || $SKIP_MAS;   then BUNDLE_ARGS="$BUNDLE_ARGS --no-mas";    fi
	if $FORMULAS_ONLY || $SKIP_CASKS; then BUNDLE_ARGS="$BUNDLE_ARGS --no-cask";   fi
	if $FORMULAS_ONLY;                 then BUNDLE_ARGS="$BUNDLE_ARGS --no-vscode"; fi

	info "Running brew update, brew bundle, brew upgrade"
	$FORMULAS_ONLY && info "formulas-only: skipping mas, casks, and vscode extensions"
	$SKIP_MAS      && ! $FORMULAS_ONLY && info "skipping Mac App Store apps"
	$SKIP_CASKS    && ! $FORMULAS_ONLY && info "skipping casks"

	brew update
	# shellcheck disable=SC2086
	brew bundle $BUNDLE_ARGS
	brew upgrade
}

set_computer_name() {
	if [[ "$(uname)" != "Darwin" ]]; then
		info "skipping computer name (not macOS)"
		return 0
	fi

	local name="$1"
	if [[ -z "$name" ]]; then
		local current
		current=$(scutil --get ComputerName 2>/dev/null || echo "")
		user " - Computer name [${current}]: "
		read -r name
		[[ -z "$name" ]] && { info "keeping current computer name: ${current}"; return 0; }
	fi

	local host_name
	host_name=$(echo "$name" | tr ' ' '-' | tr -cd '[:alnum:]-')

	sudo scutil --set ComputerName  "$name"
	sudo scutil --set HostName      "$host_name"
	sudo scutil --set LocalHostName "$host_name"
	sudo defaults write /Library/Preferences/SystemConfiguration/com.apple.smb.server \
		NetBIOSName -string "$host_name"
	success "computer name set to: $name ($host_name)"
}

install_ass() {
	info "Installing ass (AI Session Search)"
	mkdir -p "$HOME/.local/bin"
	if curl -fsSL https://github.com/kyriacos/ai-session-search/releases/latest/download/ass \
		-o "$HOME/.local/bin/ass" && chmod +x "$HOME/.local/bin/ass"; then
		success "ass installed to ~/.local/bin/ass"
	else
		fail "ass installation failed"
	fi
}

install_tmux_plugins() {
	info "Installing tmux plugins"
	if command -v tmux >/dev/null 2>&1; then
		TPM_INSTALL="$HOME/.tmux/plugins/tpm/bin/install_plugins"
		if [ -x "$TPM_INSTALL" ]; then
			"$TPM_INSTALL" && success "tmux plugins installed"
		else
			fail "TPM not found at $HOME/.tmux/plugins/tpm — did you clone with --recurse-submodules?"
		fi
	else
		info "tmux not found, skipping plugin install"
	fi
}

# --- Run ---

if $ONLY_MODE; then
	$ONLY_NAME      && set_computer_name "$COMPUTER_NAME"
	$ONLY_GITCONFIG && setup_gitconfig
	$ONLY_DOTFILES  && install_dotfiles
	$ONLY_BREW      && install_homebrew
	$ONLY_OSX       && [[ "$(uname)" == "Darwin" ]] && {
		chmod +x "$HOME/.dotfiles/osx_set_defaults.sh"
		"$HOME/.dotfiles/osx_set_defaults.sh"
	}
	$ONLY_KARABINER && install_karabiner
	$ONLY_NVIM      && install_nvim
	$ONLY_TMUX      && install_tmux_plugins
	$ONLY_ASS       && install_ass
	success "Done"
	exit 0
fi

# Full setup
set_computer_name "$COMPUTER_NAME"
$SKIP_GITCONFIG || setup_gitconfig
install_dotfiles

info 'Try setting zsh as default shell'
zsh="$(find_zsh)"
test "$(expr "$SHELL" : '.*/\(.*\)')" != "zsh" &&
	command -v chsh >/dev/null 2>&1 &&
	chsh -s "$zsh" &&
	success "set $("$zsh" --version) at $zsh as default shell"

$SKIP_BREW || install_homebrew

if ! $SKIP_OSX && [[ "$(uname)" == "Darwin" ]]; then
	info "Setting up macOS defaults"
	chmod +x "$HOME/.dotfiles/osx_set_defaults.sh"
	"$HOME/.dotfiles/osx_set_defaults.sh"
fi

install_karabiner
install_nvim
$SKIP_TMUX || install_tmux_plugins
install_ass

success "Finished set up"
